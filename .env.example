# =============================================================================
# Healthcare Claims RAG Engine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- LLM Configuration ---
# claude-sonnet-4-6 is the default (high-performance, cost-efficient)
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# --- Embedding Configuration ---
EMBEDDING_MODEL=text-embedding-3-small

# --- Vector Store ---
# "chroma" = zero-friction local ChromaDB (default)
# "qdrant" = persistent Qdrant (requires Docker: docker-compose up -d)
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/vector_store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=healthcare_policies

# --- Knowledge Base ---
POLICY_KB_DIR=./data/policy_kb

# --- FastAPI ---
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# --- n8n Integration ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook/verify-claim
N8N_API_URL=http://localhost:5678/api/v1

# --- Nightly Pipeline: EHR Source ---
# Options: csv | fhir | sql | sftp
EHR_SOURCE=csv
CSV_INPUT_PATH=data/batch_input/claims.csv

# --- FHIR API (set if EHR_SOURCE=fhir) ---
FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
FHIR_ACCESS_TOKEN=

# --- SQL Database (set if EHR_SOURCE=sql) ---
SQL_CONNECTION_STRING=postgresql://user:password@localhost:5432/claims_db
SQL_QUERY=SELECT * FROM claims WHERE submission_status = 'pending'

# --- SFTP (set if EHR_SOURCE=sftp) ---
SFTP_HOST=
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY_PATH=
SFTP_REMOTE_DIR=/exports/claims

# --- Email Reporting ---
EMAIL_ENABLED=false
EMAIL_SENDER=claims-engine@yourorg.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_PASSWORD=
EMAIL_RECIPIENTS=billing@yourorg.com

# --- Clearinghouse / Payer Auto-Submission (optional) ---
CLEARINGHOUSE_API_URL=
CLEARINGHOUSE_API_KEY=
